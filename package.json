{
    "name": "vsms",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently -n client,server -c cyan,green \"vite\" \"tsx watch server/src/index.ts\"",
        "dev:client": "vite",
        "dev:server": "tsx watch server/src/index.ts",
        "build": "vite build && tsc -p server/tsconfig.json",
        "start": "node server/dist/src/index.js",
        "preview": "vite preview",
        "test": "vitest run",
        "test:server": "vitest run --config server/vitest.config.ts",
        "test:all": "vitest run && vitest run --config server/vitest.config.ts"
    },
    "dependencies": {
        "@prisma/adapter-mariadb": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.19.0",
        "@types/react-datepicker": "^6.2.0",
        "@types/uuid": "^10.0.0",
        "exceljs": "^4.4.0",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "file-saver": "^2.0.5",
        "form-data": "^4.0.5",
        "git": "^0.1.5",
        "lucide-react": "^1.11.0",
        "mariadb": "^3.5.2",
        "multer": "^2.1.1",
        "node-fetch": "^3.3.2",
        "react": "^19.2.5",
        "react-datepicker": "^9.1.0",
        "react-dom": "^19.2.5",
        "recharts": "^3.8.1",
        "uuid": "^14.0.0",
        "xlsx": "^0.18.5",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@tailwindcss/vite": "^4.2.3",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/file-saver": "^2.0.7",
        "@types/form-data": "^2.2.1",
        "@types/multer": "^2.1.0",
        "@types/node": "^24.12.2",
        "@types/node-fetch": "^2.6.13",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/supertest": "^7.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "jsdom": "^29.0.2",
        "prisma": "^7.8.0",
        "supertest": "^7.2.2",
        "tailwindcss": "^4.2.3",
        "tsx": "^4.21.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.9",
        "vite-plugin-singlefile": "^2.3.3",
        "vitest": "^4.1.4"
    }
}
